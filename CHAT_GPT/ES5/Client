#include <iostream>
#include <stdlib.h>
#include <unistd.h>
#include <cstring>
#include <string>
#include <arpa/inet.h>
#include <netinet/in.h>
#include <sys/socket.h>
#include <thread>
#include <atomic>

using namespace std;

#define PORT 8080
#define BUFFER 1024

atomic<bool> inChat(false);

string peerIP = "";
int peerPort = 0;

void recvUDP(int socket){

    char buffer[BUFFER];

    while (true){

        struct sockaddr_in sender_addr;
        socklen_t len = sizeof(sender_addr);

        int n = recvfrom(socket, buffer, BUFFER - 1, 0, (struct sockaddr*)&sender_addr, &len);
        if (n <= 0){
            perror("Errore nella ricezione dei dati UDP");
            return;
        }

        buffer[n] = '\0';

        cout << "\nMessaggio ricevuto: " << buffer << endl;
        cout.flush();

    }

}

void sendUDP(int udpSocket, string msg){

    struct sockaddr_in peer;

    peer.sin_family = AF_INET;
    peer.sin_port = htons(peerPort);

    if (inet_pton(AF_INET, peerIP.c_str(), &peer.sin_addr) <= 0){
        cout << "IP peer non valido\n";
        return;
    }

    if (sendto(udpSocket, msg.c_str(), msg.size(), 0, (struct sockaddr*)&peer, sizeof(peer)) < 0){
        perror("Errore nell'invio UDP");
        return;
    }

}

void recvMsg(int socket){

    char buffer[BUFFER];

    while (true){

        int n = recv(socket, buffer, BUFFER - 1, 0);
        if (n <= 0){
            perror("Errore nella ricezione TCP");
            return;
        }

        buffer[n] = '\0';

        string msg(buffer);

        cout << "\n" << msg << endl;

        if (msg.find("Peer info") != string::npos){

            int pos1 = msg.find(":");
            int pos2 = msg.find(",");

            peerIP = msg.substr(pos1 + 2, pos2 - (pos1 + 2));

            pos1 = msg.find(":", pos2);
            peerPort = stoi(msg.substr(pos1 + 2));

            cout << "Chat P2P avviata con peer " << peerIP << ":" << peerPort << endl;
            cout << "Scrivi i messaggi. Scrivi 'exit' per uscire dalla chat.\n";

            inChat = true;
        }

        cout.flush();

    }

}

int main(){

    int sockfd;
    struct sockaddr_in server_addr;

    sockfd = socket(AF_INET, SOCK_STREAM, 0);
    if (sockfd < 0){
        perror("Errore nella socket TCP");
        return -1;
    }

    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(PORT);
    inet_pton(AF_INET, "127.0.0.1", &server_addr.sin_addr);

    if (connect(sockfd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0){
        perror("Errore nella connessione con il server");
        return -1;
    }

    int localUdpPort;
    cout << "Inserisci la tua porta UDP: ";
    cin >> localUdpPort;
    cin.ignore();

    int udpSocket = socket(AF_INET, SOCK_DGRAM, 0);
    if (udpSocket < 0){
        perror("Errore nella socket UDP");
        return -1;
    }

    struct sockaddr_in udpAddr;
    memset(&udpAddr, 0, sizeof(udpAddr));

    udpAddr.sin_family = AF_INET;
    udpAddr.sin_port = htons(localUdpPort);
    udpAddr.sin_addr.s_addr = INADDR_ANY;

    if (bind(udpSocket, (struct sockaddr*)&udpAddr, sizeof(udpAddr)) < 0){
        perror("Errore nel bind UDP");
        return -1;
    }

    thread tcpReceiver(recvMsg, sockfd);
    thread udpReceiver(recvUDP, udpSocket);

    tcpReceiver.detach();
    udpReceiver.detach();

    string msg;

    while (true){

        cout << "> ";
        getline(cin, msg);

        if (msg.empty()){
            continue;
        }

        if (inChat){

            sendUDP(udpSocket, msg);

            if (msg == "exit"){
                inChat = false;

                string end = "END_P2P";
                send(sockfd, end.c_str(), end.size(), 0);

                cout << "Sei uscito dalla chat P2P\n";
            }

        }else{

            if (send(sockfd, msg.c_str(), msg.size(), 0) < 0){
                perror("Errore nell'invio TCP");
                break;
            }

            if (msg == "QUIT"){
                break;
            }

        }

    }

    close(sockfd);
    close(udpSocket);

    return 0;
}
