#include <iostream>
#include <stdlib.h>
#include <unistd.h>
#include <cstring>
#include <string>
#include <arpa/inet.h>
#include <netinet/in.h>
#include <sys/socket.h>
#include <thread>

#define PORT 8080
#define BUFFER 1024

using namespace std;

void rcvMsg(int socket){

    while (true){

        char buffer[BUFFER];
        int n;

        n = recv(socket, buffer, BUFFER - 1, 0);
        if (n <= 0){
            perror("Errore nella ricezione dei dati o client disconnesso\n");
            return;
        }
        buffer[n] = '\0';

        cout << buffer << endl;

    }

}

void sendMsg(int socket){

    string msg;

    while (true){

        getline(cin, msg);

        if ((send(socket, msg.c_str(), msg.size(), 0)) < 0){
            perror("Errore nell'invio dei dati\n");
            return;
        }

    }

}


int main(){

    int sockfd;
    struct sockaddr_in server_addr;
    socklen_t len = sizeof(server_addr);

    sockfd = socket(AF_INET, SOCK_STREAM, 0);
    if (sockfd < 0){
        perror("Errore nella socket\n");
        return -1;
    }

    server_addr.sin_port = htons(PORT);
    server_addr.sin_family = AF_INET;
    inet_pton(AF_INET, "127.0.0.1", &server_addr.sin_addr);

    if ((connect(sockfd, (struct sockaddr*)&server_addr, len)) < 0){
        perror("Errore nella connessione con il server\n");
        return -1;
    }
    cout << "Connesso al server...\n";

    thread t1(rcvMsg, sockfd);
    thread t2(sendMsg, sockfd);

    t1.join();
    t2.join();

    close(sockfd);
    
    return 0;

}
